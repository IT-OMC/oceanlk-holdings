# Copy this file to .env and fill in values for local development.
# Never commit .env to git.

# PostgreSQL / Supabase connection
DATABASE_URL=jdbc:postgresql://localhost:5432/oceanlk
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRATION=3600000

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# CORS (comma-separated origins allowed to call the API)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Google Gemini AI
GEMINI_API_KEY=

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Seeded admin credentials (change these before going to production)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_SUPERADMIN_USERNAME=superadmin
DEFAULT_SUPERADMIN_PASSWORD=

# Redis (for distributed rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
