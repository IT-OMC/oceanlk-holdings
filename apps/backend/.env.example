# ============================================
# Gemini API Configuration
# ============================================
# Get your API key from: https://aistudio.google.com/
# Make sure the "Generative Language API" is enabled in Google Cloud Console
# Ensure billing is configured in your Google Cloud/AI Studio account
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default Gemini API URL
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# ============================================
# MongoDB Configuration
# ============================================
# IMPORTANT: Use the full MongoDB connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# For local development: mongodb://localhost:27017/oceanlk
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.example.mongodb.net/oceanlk?retryWrites=true&w=majority&appName=Cluster0

# JWT Configuration
# Generate a cryptographically strong secret: openssl rand -base64 32
# NEVER use a short or human-readable string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Expiry in ms — default 1h (3600000). Increase only if needed.
JWT_EXPIRATION=3600000

# Email Configuration (SMTP)
# Configure these values with your actual SMTP credentials
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here

# Email Addresses
EMAIL_FROM=noreply@oceanlk.com
EMAIL_HR=hr@omc.lk

# Server Configuration
SERVER_PORT=8080

# Spring Profile (use 'prod' for production, leave blank for dev defaults)
SPRING_PROFILES_ACTIVE=prod

# Redis Configuration (for distributed rate limiting)
# Generate password: openssl rand -base64 24
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_SSL=false

# Rate Limiting
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60000

# CORS Configuration (Production)
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://ocean.lk,https://www.ocean.lk

# Default Admin Credentials (for initial setup only)
# IMPORTANT: Change these immediately after first login
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_this_password_123
DEFAULT_SUPERADMIN_USERNAME=superadmin
DEFAULT_SUPERADMIN_PASSWORD=change_this_password_456
